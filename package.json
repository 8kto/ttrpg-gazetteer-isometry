    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-plugin-transform-import-meta": "^2.2.1",
