{
  "name": "ttrpg-gazetteer-isometry",
  "version": "0.0.1",
  "license": "CC-BY-NC-4.0",
  "description": "A gazetteer for TTRPG module",
  "author": "8kto <ifhtagn@gmail.com>",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "test": "jest",
    "format": "prettier . --check",
    "format:fix": "yarn lint --fix && prettier --write .",
    "prebuild": "rm -rf ./build/*",
    "build:styles": "npx tailwindcss -i ./src/styles/styles.css -o ./build/output.css",
    "watch:styles": "yarn build:styles --watch",
    "watch": "nodemon",
    "dev": "npx http-server ./build/chunks-html -p 3000"
  },
  "imports": {
    "#lib/*": "./scripts/lib/*",
    "#commands/*": "./scripts/commands/*"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "chalk": "^5.3.0",
    "ejs": "^3.1.9",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "html-pdf": "^3.0.1",
    "html-toc": "^2.0.0",
    "hyphenopoly": "^5.3.0",
    "markdown-it": "^14.0.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^21.7.0",
    "tailwindcss": "^3.4.1",
    "transliteration": "^2.3.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.10",
    "@babel/plugin-syntax-import-assertions": "^7.23.3",
    "@babel/preset-env": "^7.23.9",
    "babel-plugin-transform-import-meta": "^2.2.1",
    "eslint": "^8",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^48.0.2",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.7"
  }
}
