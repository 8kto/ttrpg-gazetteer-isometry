    "hyphenopoly": "^5.3.0",
    "hypher": "^0.2.5",
    "jsdom": "^27.0.0",
    "markdown-it": "^14.0.0",
    "markdown-it-ins": "^4.0.0",
    "pdf-lib": "^1.17.1",
